region = "us-east-1"

azs = [
  "us-east-1a",
  "us-east-1b"
]

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_subnet_cidrs = [
  "10.0.3.0/24",
  "10.0.4.0/24"
]

web_instance_type     = "t3.micro"
bastion_instance_type = "t3.micro"
db_instance_type      = "t3.small"

key_name = "techcorp-key"

my_ip = "YOUR_IP/32"

web_user_password = "your-strong-password-here"
db_user_password  = "your-strong-password-here"